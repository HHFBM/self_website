# Server
PORT=8787
MAX_UPLOAD_MB=8

# AI provider switch
# mock: no external API call, returns uploaded visitor image for end-to-end testing
# custom: call external API endpoint below
AI_PROVIDER=mock
AI_MODEL=YOUR_MODEL_NAME

# External API config (used when AI_PROVIDER=custom)
AI_API_URL=https://your-api-endpoint.example.com/generate
AI_API_KEY=YOUR_API_KEY_HERE
AI_API_AUTH_HEADER=Authorization
AI_API_AUTH_SCHEME=Bearer
AI_TIMEOUT_MS=60000

# Client dev proxy target (optional)
# VITE_API_PROXY_TARGET=http://localhost:8787
